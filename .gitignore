# Type-check stubs from setuptools-scm if used later
_version.py

# Local config — users set WOWS_WORKSPACE / WOWS_GAME_DIR / WOWS_TOOLKIT_BIN
# via env vars or a personal config file; the file itself is not committed.
wows_model_export.toml
.env
.env.local

# Workspace data must never enter the public mirror. Even though the
# convention puts workspace at $WOWS_WORKSPACE (default outside the repo),
# guard against accidental in-repo workspace dirs from local experiments.
/workspace/
/.cache/
/libraries/
/maps/

# Scratch / ad-hoc work
scratch/
tmp/
*.tmp

# local-only context, never published.
/reference/

# Claude Code local diagnostics (session-termination investigation)
.claude/settings.local.json
.claude/hooks/
.claude/*.log
.claude/repro-capture.ps1
.claude/repro-result.log
.claude/*HANDOFF*.md

# Claude Code project MCP config (machine-specific absolute paths; local-only)
/.mcp.json

# Webview build artifacts (webview/.gitignore handles its own subtree;
# this catches in case a build leaks up).
/webview/dist/
/webview/node_modules/
# Build-time mirror of webview/dist consumed by setuptools package_data
# and PyInstaller. Populated locally by `npm run build` (the resolver
# in server/static.py falls back to webview/dist when this is empty) or
# by CI before wheel/exe builds. Not source — never commit.
/src/wows_model_export/_static/webview/
tools/*